# --- NDA signature storage -------------------------------------------------
# Local dev: leave TURSO_* empty → signatures are written to a real SQLite file
# at data/signatures.sqlite (grab it directly, or via /api/nda/export).
#
# Vercel: the filesystem is ephemeral, so create a free Turso database
# (SQLite-compatible) and set both values in Vercel → Project → Settings →
# Environment Variables:
#   turso db create jetsetterpro-nda
#   turso db show jetsetterpro-nda --url
#   turso db tokens create jetsetterpro-nda
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Admin key protecting GET /api/nda and /api/nda/export — CHANGE THIS.
NDA_ADMIN_KEY=change-me
